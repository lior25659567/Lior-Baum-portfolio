    {
      "type": "goals",
      "label": "Design Goals",
      "title": "Four problems. Four things to get right.",
      "goals": [
        {
          "number": "1",
          "title": "Start without friction",
          "description": "Remove the setup gates that block users before scanning."
        },
        {
          "number": "2",
          "title": "Keep scanning unbroken",
          "description": "Stop the interface from interrupting the act of scanning."
        },
        {
          "number": "3",
          "title": "Make every tool self-explanatory",
          "description": "Clarity built in — not figured out over time."
        },
        {
          "number": "4",
          "title": "Make results trustworthy on first view",
          "description": "A clear signal that the scan is done — no re-checks."
        }
      ],
      "kpis": [
        "Time from RX entry to first scan action",
        "Number of tool interactions mid-scan",
        "Rescan rate per case",
        "Self-reported confidence in scan result"
      ],
      "goalsCardsTitle": "Goals",
      "gridColumns": 2,
      "cardHeight": "100",
      "kpisGridColumns": 2,
