    {
      "type": "problem",
      "label": "The Problem",
      "title": "The system grew. The experience didn't.",
      "content": "RX, Scan, and View were built up over time with no shared logic — three disconnected systems instead of one workflow.",
      "issuesTitle": "Where it broke down",
      "issues": [
        "Setup blocked users before they could scan",
        "Procedure and tooth selection took too much effort",
        "Scanning stopped every time a tool needed adjusting",
        "Nothing signalled when a scan was complete"
      ],
